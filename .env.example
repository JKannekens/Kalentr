# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kalentr"

# NextAuth
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# SSO (optional — buttons only appear when a provider is configured)
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Microsoft: https://portal.azure.com > Entra ID > App registrations
#   Redirect URI: {AUTH_URL}/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Optional; defaults to "common" (personal + work accounts). For a single
# tenant use https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@kalentr.com"

# App
NEXT_PUBLIC_ROOT_DOMAIN="kalentr.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron (optional — for appointment reminders endpoint)
CRON_SECRET="generate-a-random-secret-here"

# Seed (optional, local development only) — when set, `prisma db seed`
# gives the demo account a password so you can log into its dashboard.
# Leave unset when seeding production: the demo login stays disabled.
SEED_DEMO_PASSWORD=""

# Stripe
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID="price_xxxxxxxxxxxxxxxxxxxx"
